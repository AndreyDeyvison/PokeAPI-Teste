<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="641.0" prefWidth="952.0" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.projetoapigrafospokeapi.HelloController">
   <stylesheets>
      <URL value="@../../../style.css" />
   </stylesheets>
   <children>
      <AnchorPane layoutX="13.0" layoutY="5.0" opacity="0.64" prefHeight="625.0" prefWidth="926.0" style="-fx-background-color: #ffffff; -fx-background-radius: 20; -fx-effect: dropshadow(three-pass-box, rgb(181, 181, 181), 4, 0, 0, 2);" />
      <AnchorPane layoutX="26.0" layoutY="17.0" prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #b22222; -fx-background-radius: 20;">
         <children>
            <Button fx:id="validar" layoutX="718.0" layoutY="14.0" mnemonicParsing="false" onAction="#validarPokeDex" prefHeight="35.0" prefWidth="121.0" styleClass="botaoValidar" text="Validar" />
         </children>
      </AnchorPane>
      <HBox fx:id="logoApp" alignment="CENTER" layoutX="70.0" layoutY="20.0" prefHeight="53.0" prefWidth="305.0" spacing="20.0">
         <children>
            <ImageView fitHeight="50.0" fitWidth="50.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../../../imagens/pokebola.png" />
               </image>
            </ImageView>
            <Text strokeType="OUTSIDE" strokeWidth="0.0" styleClass="tituloApp" text="Validar Pokedex" />
            <ImageView fitHeight="50.0" fitWidth="50.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../../../imagens/pikachu.png" />
               </image>
            </ImageView>
         </children>
      </HBox>
      <AnchorPane layoutX="63.0" layoutY="89.0" prefHeight="436.0" prefWidth="823.0" style="-fx-background-radius: 20; -fx-background-color: #ffffff;">
         <children>
            <ScrollPane hbarPolicy="NEVER" layoutX="20.0" layoutY="14.0" prefHeight="359.0" prefWidth="786.0" style="-fx-background-color: transparent;" vbarPolicy="NEVER">
               <content>
                  <VBox fx:id="listaPokedex" prefHeight="375.0" prefWidth="790.0" style="-fx-background-color: #ffffff;" />
               </content>
            </ScrollPane>
            <StackPane layoutX="14.0" layoutY="380.0" prefHeight="50.0" prefWidth="802.0">
               <children>
                  <Text fx:id="textoResposta" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="resposta" text="Aguardando Inserir Pokemons" />
               </children>
            </StackPane>
         </children></AnchorPane>
      <AnchorPane layoutX="62.0" layoutY="547.0" prefHeight="53.0" prefWidth="823.0" style="-fx-background-radius: 20; -fx-background-color: #ffffff;">
         <children>
            <HBox alignment="CENTER" layoutX="10.0" layoutY="9.0" prefHeight="35.0" prefWidth="802.0" spacing="10.0" style="-fx-border-width: 0 0 0 0; -fx-border-color: #000000;">
               <children>
                  <ImageView fitHeight="32.0" fitWidth="24.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@../../../imagens/pesquisar.png" />
                     </image>
                  </ImageView>
                  <TextField fx:id="entradaPoke" prefHeight="35.0" prefWidth="767.0" promptText="Insira o Nome do Pokemon" styleClass="cadastro-textField" />
               </children>
            </HBox>
         </children>
      </AnchorPane>
   </children>
</AnchorPane>
